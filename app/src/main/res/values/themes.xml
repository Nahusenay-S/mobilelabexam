<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose handles all UI theming. This base theme just suppresses the action bar
         and makes the system bars transparent so Compose can draw edge-to-edge. -->
    <style name="Theme.NotesQuote" parent="android:Theme.Material.Light.NoActionBar">

        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
